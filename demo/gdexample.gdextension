[configuration]

entry_symbol = "distutils_library_init"
compatibility_minimum = "4.3"
reloadable = true


[libraries]

windows.debug.x86_32 = "res://bin/libdistutils.windows.template_debug.x86_32.dll"
windows.release.x86_32 = "res://bin/libdistutils.windows.template_release.x86_32.dll"
windows.debug.x86_64 = "res://bin/libdistutils.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/libdistutils.windows.template_release.x86_64.dll"
